---
import '../styles/global.css';
import { colors, fonts, logo } from '../config/theme.mjs';
import site from '../content/settings/site.json';
const { brand, ctaLabel, nav, contact, social, footerTagline, footerPages, footerLinks, footerBottomLinks, copyright } = site;
const contactIcons: Record<string, string> = { phone: 'schedule', email: 'mail', location: 'location_on' };
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Alethig Media — Agencia de marketing digital de Long Island. Manejo de redes sociales, producción de video y publicidad pagada en inglés y español.' } = Astro.props;

// --- Tema → variables CSS que consume global.css (única fuente: src/config/theme.mjs) ---
const hexToRgb = (hex: string) => {
  const h = hex.replace('#', '');
  const n = parseInt(h.length === 3 ? h.split('').map(c => c + c).join('') : h, 16);
  return `${(n >> 16) & 255}, ${(n >> 8) & 255}, ${n & 255}`;
};
const accentRgb = hexToRgb(colors.accent);
const cssVars: Record<string, string> = {
  '--bg-void': colors['bg-void'],
  '--bg-depth': colors['bg-depth'],
  '--accent': colors.accent,
  '--accent-2': colors['accent-2'],
  '--text-primary': colors['text-primary'],
  '--text-secondary': colors['text-secondary'],
  '--text-dim': colors['text-dim'],
  '--grad-indigo': colors['grad-indigo'],
  '--grad-violet': colors['grad-violet'],
  '--grad-pink': colors['grad-pink'],
  '--accent-rgb': accentRgb,
  '--accent-2-rgb': hexToRgb(colors['accent-2']),
  '--accent-dim': `rgba(${accentRgb}, 0.08)`,
  '--accent-glow': `0 0 40px rgba(${accentRgb}, 0.30)`,
  '--accent-glow-strong': `0 0 80px rgba(${accentRgb}, 0.45)`,
  '--glass-border-accent': `rgba(${accentRgb}, 0.28)`,
  '--font-display': fonts.display,
  '--font-body': fonts.body,
};
const rootStyle = ':root{' + Object.entries(cssVars).map(([k, v]) => `${k}:${v}`).join(';') + '}';
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href={fonts.googleHref} rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />
  <style set:html={rootStyle}></style>
</head>
<body class="noise-overlay">

  <!-- NAV -->
  <header id="site-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500">
    <div class="max-w-container-max mx-auto px-gutter">
      <div class="flex items-center justify-between h-20 transition-all duration-300" id="nav-inner">
        <!-- Logo -->
        <a href="/" class="flex items-center group" aria-label={brand}>
          {logo.image
            ? <img src={logo.image} alt={logo.alt} class="h-9 w-auto" />
            : <span class="font-display font-bold text-lg tracking-tight text-text-primary group-hover:text-accent transition-colors duration-300">{brand}</span>
          }
        </a>

        <!-- Desktop Nav -->
        <nav class="hidden md:flex items-center gap-8">
          {nav.map(item => (
            <a href={item.href} class="text-label-sm text-text-secondary hover:text-text-primary transition-colors duration-200 uppercase tracking-widest">{item.label}</a>
          ))}
        </nav>

        <!-- CTA + Mobile toggle -->
        <div class="flex items-center gap-4">
          <div class="hidden md:block">
            <a href="/contacto" class="btn-cyber press">
              <span class="icon-wrap">{ctaLabel} <span class="material-symbols-outlined text-base">arrow_forward</span></span>
            </a>
          </div>
          <button id="menu-btn" class="md:hidden glass p-2 rounded-lg" aria-label="Menú">
            <span class="material-symbols-outlined text-text-primary">menu</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden glass mx-4 mb-4 rounded-2xl overflow-hidden">
      <nav class="flex flex-col p-4 gap-1">
        {nav.map(item => (
          <a href={item.href} class="px-4 py-3 text-text-secondary hover:text-accent rounded-lg transition-all text-sm font-display font-semibold uppercase tracking-widest">{item.label}</a>
        ))}
        <div class="pt-2 mt-1 border-t border-[rgba(255,255,255,0.07)]">
          <a href="/contacto" class="btn-cyber-solid w-full justify-center text-center block">{ctaLabel}</a>
        </div>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <!-- FOOTER -->
  <footer class="mesh-bg-alt lumen-border mt-0">
    <div class="max-w-container-max mx-auto px-gutter py-section-py-sm">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-10 mb-16">
        <!-- Brand -->
        <div>
          <a href="/" class="inline-flex mb-4" aria-label={brand}>
            {logo.image
              ? <img src={logo.image} alt={logo.alt} class="h-10 w-auto" />
              : <span class="font-display font-bold text-lg text-text-primary">{brand}</span>
            }
          </a>
          <p class="text-text-secondary text-sm leading-relaxed mb-5">{footerTagline}</p>
          <div class="flex gap-3">
            {social?.instagram && (
              <a href={social.instagram} target="_blank" rel="noopener" class="glass p-2 rounded-lg hover:border-accent/40 transition-all" aria-label="Instagram">
                <svg class="w-5 h-5 fill-current text-text-secondary" viewBox="0 0 24 24"><path d="M12 2.2c3.2 0 3.6 0 4.9.07 1.2.06 1.8.25 2.2.42.6.22 1 .48 1.4.9.42.4.68.8.9 1.4.17.4.36 1 .42 2.2.06 1.3.07 1.7.07 4.9s0 3.6-.07 4.9c-.06 1.2-.25 1.8-.42 2.2-.22.6-.48 1-.9 1.4-.4.42-.8.68-1.4.9-.4.17-1 .36-2.2.42-1.3.06-1.7.07-4.9.07s-3.6 0-4.9-.07c-1.2-.06-1.8-.25-2.2-.42-.6-.22-1-.48-1.4-.9-.42-.4-.68-.8-.9-1.4-.17-.4-.36-1-.42-2.2C2.2 15.6 2.2 15.2 2.2 12s0-3.6.07-4.9c.06-1.2.25-1.8.42-2.2.22-.6.48-1 .9-1.4.4-.42.8-.68 1.4-.9.4-.17 1-.36 2.2-.42C8.4 2.2 8.8 2.2 12 2.2zm0 1.8c-3.1 0-3.5 0-4.7.07-.9.04-1.4.2-1.7.32-.43.17-.74.37-1.06.7-.32.32-.52.63-.7 1.06-.12.3-.28.8-.32 1.7C3.45 8.5 3.45 8.9 3.45 12s0 3.5.07 4.7c.04.9.2 1.4.32 1.7.17.43.37.74.7 1.06.32.32.63.52 1.06.7.3.12.8.28 1.7.32 1.2.06 1.6.07 4.7.07s3.5 0 4.7-.07c.9-.04 1.4-.2 1.7-.32.43-.17.74-.37 1.06-.7.32-.32.52-.63.7-1.06.12-.3.28-.8.32-1.7.06-1.2.07-1.6.07-4.7s0-3.5-.07-4.7c-.04-.9-.2-1.4-.32-1.7-.17-.43-.37-.74-.7-1.06-.32-.32-.63-.52-1.06-.7-.3-.12-.8-.28-1.7-.32-1.2-.06-1.6-.07-4.7-.07zm0 3.06A4.94 4.94 0 1 1 12 17a4.94 4.94 0 0 1 0-9.88zm0 1.8a3.14 3.14 0 1 0 0 6.28 3.14 3.14 0 0 0 0-6.28zm5.15-3.2a1.15 1.15 0 1 1 0 2.3 1.15 1.15 0 0 1 0-2.3z"/></svg>
              </a>
            )}
            {social?.facebook && (
              <a href={social.facebook} target="_blank" rel="noopener" class="glass p-2 rounded-lg hover:border-accent/40 transition-all" aria-label="Facebook">
                <svg class="w-5 h-5 fill-current text-text-secondary" viewBox="0 0 24 24"><path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.78-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.44 2.89h-2.34v6.99A10 10 0 0 0 22 12z"/></svg>
              </a>
            )}
            {social?.tiktok && (
              <a href={social.tiktok} target="_blank" rel="noopener" class="glass p-2 rounded-lg hover:border-accent/40 transition-all" aria-label="TikTok">
                <svg class="w-5 h-5 fill-current text-text-secondary" viewBox="0 0 24 24"><path d="M16.6 5.82a4.28 4.28 0 0 1-1.06-2.82h-3.2v12.9a2.59 2.59 0 1 1-2.59-2.59c.27 0 .53.04.77.12v-3.3a5.9 5.9 0 0 0-.77-.05A5.9 5.9 0 1 0 15.65 16V9.6a7.43 7.43 0 0 0 4.35 1.4V7.7a4.28 4.28 0 0 1-3.4-1.88z"/></svg>
              </a>
            )}
          </div>
        </div>

        <!-- Contact -->
        <div>
          <p class="tag-cyber mb-5">Contacto</p>
          <ul class="space-y-3">
            {Object.entries(contact).map(([key, value]) => (
              <li class="flex items-center gap-3 text-text-secondary text-sm">
                <span class="material-symbols-outlined text-accent text-base">{contactIcons[key] ?? 'circle'}</span>
                {value}
              </li>
            ))}
          </ul>
        </div>

        <!-- Pages -->
        <div>
          <p class="tag-cyber mb-5">Páginas</p>
          <ul class="space-y-2">
            {footerPages.map(item => (
              <li><a href={item.href} class="text-text-secondary text-sm hover:text-accent transition-colors duration-200">{item.label}</a></li>
            ))}
          </ul>
        </div>

        <!-- Quick links -->
        <div>
          <p class="tag-cyber mb-5">Enlaces</p>
          <ul class="space-y-2">
            {footerLinks.map(item => (
              <li><a href={item.href} class="text-text-secondary text-sm hover:text-accent transition-colors duration-200">{item.label}</a></li>
            ))}
          </ul>
        </div>
      </div>

      <div class="cyber-divider mb-8"></div>
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="text-text-dim text-sm">{copyright}</p>
        <div class="flex gap-6">
          {footerBottomLinks.map(item => (
            <a href={item.href} class="text-text-dim text-sm hover:text-text-secondary transition-colors">{item.label}</a>
          ))}
        </div>
      </div>
    </div>
  </footer>

</body>
</html>

<script>
  // ---- Scroll: sticky nav glassify ----
  const nav = document.getElementById('site-nav');
  const navInner = document.getElementById('nav-inner');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      nav!.style.cssText = 'background:rgba(0,3,38,0.82);backdrop-filter:blur(24px) saturate(180%);-webkit-backdrop-filter:blur(24px) saturate(180%);border-bottom:1px solid rgba(255,255,255,0.07);';
      navInner!.style.height = '64px';
    } else {
      nav!.style.cssText = '';
      navInner!.style.height = '80px';
    }
  }, { passive: true });

  // ---- Mobile menu ----
  document.getElementById('menu-btn')?.addEventListener('click', () => {
    const m = document.getElementById('mobile-menu');
    m?.classList.toggle('hidden');
  });

  // ---- IntersectionObserver: reveal + stagger-fade ----
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); }
    });
  }, { threshold: 0.12 });
  document.querySelectorAll('.reveal, .stagger-fade').forEach(el => io.observe(el));

  // ---- Magnetic buttons ----
  document.querySelectorAll('.magnetic').forEach(el => {
    el.addEventListener('mousemove', (e: MouseEvent) => {
      const r = (el as HTMLElement).getBoundingClientRect();
      const x = (e.clientX - r.left - r.width / 2) * 0.35;
      const y = (e.clientY - r.top - r.height / 2) * 0.35;
      (el as HTMLElement).style.transform = `translate(${x}px,${y}px)`;
    });
    el.addEventListener('mouseleave', () => { (el as HTMLElement).style.transform = ''; });
  });
</script>

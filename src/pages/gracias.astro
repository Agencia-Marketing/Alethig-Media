---
import Layout from '../layouts/Layout.astro';
import gracias from '../content/pages/gracias.json';

export const prerender = true;
---
<Layout title={gracias.title} noindex>
  <section class="mesh-bg relative pt-32 pb-section-py-lg overflow-hidden min-h-[70vh] flex items-center">
    <div class="absolute top-1/4 right-1/3 w-72 h-72 rounded-full bg-accent/5 blur-[100px] pointer-events-none"></div>
    <div class="max-w-container-max mx-auto px-gutter w-full">
      <div class="glass lumen-border rounded-2xl p-10 text-center reveal max-w-xl mx-auto">
        <div class="w-14 h-14 rounded-2xl bg-accent/10 border border-accent/20 flex items-center justify-center mx-auto mb-6">
          <span class="material-symbols-outlined text-accent text-3xl">check_circle</span>
        </div>
        <h1 class="font-display text-headline-lg-mobile md:text-headline-md mb-4">{gracias.heading}</h1>
        <p class="text-text-secondary text-body-md mb-8">{gracias.paragraph}</p>
        <a href="/" class="btn-cyber-solid justify-center press inline-flex">
          <span class="icon-wrap">{gracias.ctaLabel} <span class="material-symbols-outlined text-base">arrow_forward</span></span>
        </a>
      </div>
    </div>
  </section>
</Layout>

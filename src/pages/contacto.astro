---
import Layout from '../layouts/Layout.astro';
import contact from '../content/pages/contact.json';
import site from '../content/settings/site.json';
import { highlightHeading } from '../lib/highlight';

export const prerender = true;

const { phone, email } = site.contact;
const { social } = site;
---
<Layout title={contact.title} description={contact.metaDescription}>

  <!-- HERO -->
  <section class="mesh-bg relative pt-32 pb-section-py-sm overflow-hidden">
    <div class="absolute top-1/4 right-1/3 w-72 h-72 rounded-full bg-accent/5 blur-[100px] pointer-events-none"></div>
    <div class="max-w-container-max mx-auto px-gutter">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="reveal">
          <span class="tag-cyber mb-5 inline-flex"><span class="material-symbols-outlined text-sm">mail</span>{contact.heroTag}</span>
          <h1 class="font-display text-display-hero-mobile md:text-5xl font-extrabold mb-5" set:html={highlightHeading(contact.heroHeading, contact.heroHighlight)}></h1>
          <p class="text-body-lg text-text-secondary">
            {contact.heroParagraph}
          </p>
        </div>
        <div class="reveal">
          <div class="glass card-cyber rounded-2xl overflow-hidden animate-float">
            <img
              src={contact.heroImage}
              alt={contact.heroImageAlt}
              class="w-full aspect-square object-cover opacity-80"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FORM SECTION -->
  <section class="bg-bg-depth py-section-py-sm md:py-section-py-lg">
    <div class="max-w-container-max mx-auto px-gutter">
      <div class="grid md:grid-cols-2 gap-14 items-start">
        <!-- Left: info -->
        <div class="reveal">
          <h2 class="font-display text-headline-lg-mobile md:text-headline-md mb-4">{contact.formInfoHeading}</h2>
          <p class="text-text-secondary text-body-md mb-8 leading-relaxed">
            {contact.formInfoText}
          </p>
          <div class="space-y-5 mb-10">
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 rounded-xl bg-accent/10 border border-accent/20 flex items-center justify-center flex-shrink-0">
                <span class="material-symbols-outlined text-accent text-base">mail</span>
              </div>
              <div>
                <p class="text-text-dim text-xs uppercase tracking-widest font-display font-semibold mb-0.5">Email</p>
                <p class="text-text-primary text-sm">{email}</p>
              </div>
            </div>
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 rounded-xl bg-accent/10 border border-accent/20 flex items-center justify-center flex-shrink-0">
                <span class="material-symbols-outlined text-accent text-base">schedule</span>
              </div>
              <div>
                <p class="text-text-dim text-xs uppercase tracking-widest font-display font-semibold mb-0.5">Horario</p>
                <p class="text-text-primary text-sm">{phone}</p>
              </div>
            </div>
          </div>
          <div>
            <p class="tag-cyber mb-4">Redes Sociales</p>
            <div class="flex gap-3">
              {social?.instagram && (
                <a href={social.instagram} target="_blank" rel="noopener" class="glass p-3 rounded-xl hover:border-accent/40 transition-all group" aria-label="Instagram">
                  <svg class="w-5 h-5 fill-current text-text-secondary group-hover:text-accent transition-colors" viewBox="0 0 24 24"><path d="M12 2.2c3.2 0 3.6 0 4.9.07 1.2.06 1.8.25 2.2.42.6.22 1 .48 1.4.9.42.4.68.8.9 1.4.17.4.36 1 .42 2.2.06 1.3.07 1.7.07 4.9s0 3.6-.07 4.9c-.06 1.2-.25 1.8-.42 2.2-.22.6-.48 1-.9 1.4-.4.42-.8.68-1.4.9-.4.17-1 .36-2.2.42-1.3.06-1.7.07-4.9.07s-3.6 0-4.9-.07c-1.2-.06-1.8-.25-2.2-.42-.6-.22-1-.48-1.4-.9-.42-.4-.68-.8-.9-1.4-.17-.4-.36-1-.42-2.2C2.2 15.6 2.2 15.2 2.2 12s0-3.6.07-4.9c.06-1.2.25-1.8.42-2.2.22-.6.48-1 .9-1.4.4-.42.8-.68 1.4-.9.4-.17 1-.36 2.2-.42C8.4 2.2 8.8 2.2 12 2.2zm0 1.8c-3.1 0-3.5 0-4.7.07-.9.04-1.4.2-1.7.32-.43.17-.74.37-1.06.7-.32.32-.52.63-.7 1.06-.12.3-.28.8-.32 1.7C3.45 8.5 3.45 8.9 3.45 12s0 3.5.07 4.7c.04.9.2 1.4.32 1.7.17.43.37.74.7 1.06.32.32.63.52 1.06.7.3.12.8.28 1.7.32 1.2.06 1.6.07 4.7.07s3.5 0 4.7-.07c.9-.04 1.4-.2 1.7-.32.43-.17.74-.37 1.06-.7.32-.32.52-.63.7-1.06.12-.3.28-.8.32-1.7.06-1.2.07-1.6.07-4.7s0-3.5-.07-4.7c-.04-.9-.2-1.4-.32-1.7-.17-.43-.37-.74-.7-1.06-.32-.32-.63-.52-1.06-.7-.3-.12-.8-.28-1.7-.32-1.2-.06-1.6-.07-4.7-.07zm0 3.06A4.94 4.94 0 1 1 12 17a4.94 4.94 0 0 1 0-9.88zm0 1.8a3.14 3.14 0 1 0 0 6.28 3.14 3.14 0 0 0 0-6.28zm5.15-3.2a1.15 1.15 0 1 1 0 2.3 1.15 1.15 0 0 1 0-2.3z"/></svg>
                </a>
              )}
              {social?.facebook && (
                <a href={social.facebook} target="_blank" rel="noopener" class="glass p-3 rounded-xl hover:border-accent/40 transition-all group" aria-label="Facebook">
                  <svg class="w-5 h-5 fill-current text-text-secondary group-hover:text-accent transition-colors" viewBox="0 0 24 24"><path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.78-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.44 2.89h-2.34v6.99A10 10 0 0 0 22 12z"/></svg>
                </a>
              )}
              {social?.tiktok && (
                <a href={social.tiktok} target="_blank" rel="noopener" class="glass p-3 rounded-xl hover:border-accent/40 transition-all group" aria-label="TikTok">
                  <svg class="w-5 h-5 fill-current text-text-secondary group-hover:text-accent transition-colors" viewBox="0 0 24 24"><path d="M16.6 5.82a4.28 4.28 0 0 1-1.06-2.82h-3.2v12.9a2.59 2.59 0 1 1-2.59-2.59c.27 0 .53.04.77.12v-3.3a5.9 5.9 0 0 0-.77-.05A5.9 5.9 0 1 0 15.65 16V9.6a7.43 7.43 0 0 0 4.35 1.4V7.7a4.28 4.28 0 0 1-3.4-1.88z"/></svg>
                </a>
              )}
            </div>
          </div>
        </div>

        <!-- Right: form -->
        <div class="reveal">
          <div class="glass lumen-border rounded-2xl p-8">
            <div id="form-wrap">
            <div id="form-error" class="hidden tag-cyber !text-red-300 !border-red-400/30 mb-4">
              <span class="material-symbols-outlined text-sm">error</span> Hubo un problema. Intenta de nuevo.
            </div>
            <form id="contact-form" class="space-y-5" method="POST" action="/api/contact" novalidate>
              <div class="absolute left-[-9999px]" aria-hidden="true">
                <label>No llenar<input type="text" name="website" tabindex="-1" autocomplete="off" /></label>
              </div>
              <div class="grid sm:grid-cols-2 gap-5">
                <div>
                  <label class="block text-text-secondary text-xs uppercase tracking-widest font-display font-semibold mb-2">Tu Nombre</label>
                  <input type="text" name="nombre" placeholder="Tu nombre" class="input-cyber" required />
                </div>
                <div>
                  <label class="block text-text-secondary text-xs uppercase tracking-widest font-display font-semibold mb-2">Nombre del Negocio</label>
                  <input type="text" name="negocio" placeholder="Tu negocio" class="input-cyber" required />
                </div>
              </div>
              <div class="grid sm:grid-cols-2 gap-5">
                <div>
                  <label class="block text-text-secondary text-xs uppercase tracking-widest font-display font-semibold mb-2">Número de Teléfono</label>
                  <input type="tel" name="telefono" placeholder="(631) 000-0000" class="input-cyber" required />
                </div>
                <div>
                  <label class="block text-text-secondary text-xs uppercase tracking-widest font-display font-semibold mb-2">Correo Electrónico</label>
                  <input type="email" name="email" placeholder="tu@correo.com" class="input-cyber" required />
                </div>
              </div>
              <div>
                <label class="block text-text-secondary text-xs uppercase tracking-widest font-display font-semibold mb-2">Servicio de Interés</label>
                <select name="servicio" class="input-cyber">
                  <option value="" disabled selected>Selecciona un servicio</option>
                  {contact.serviceOptions.map(o => (
                    <option value={o.value}>{o.label}</option>
                  ))}
                </select>
              </div>
              <div>
                <label class="block text-text-secondary text-xs uppercase tracking-widest font-display font-semibold mb-2">Cuéntanos sobre tu negocio</label>
                <textarea name="mensaje" rows="4" placeholder="¿Qué te gustaría lograr?" class="input-cyber resize-none"></textarea>
              </div>
              <button type="submit" class="btn-cyber-solid w-full justify-center magnetic press">
                {contact.submitLabel}
              </button>
            </form>
            <div id="form-success" class="hidden text-center py-6">
              <div class="w-14 h-14 rounded-2xl bg-accent/10 border border-accent/20 flex items-center justify-center mx-auto mb-5">
                <span class="material-symbols-outlined text-accent text-3xl">check_circle</span>
              </div>
              <h3 class="font-display text-headline-lg-mobile mb-2">¡Mensaje enviado!</h3>
              <p class="text-text-secondary text-body-md">Gracias. Te responderemos muy pronto.</p>
            </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- MAP STRIP -->
  <section class="mesh-bg-alt py-16">
    <div class="max-w-container-max mx-auto px-gutter flex justify-center">
      <div class="glass lumen-border rounded-2xl px-8 py-5 flex items-center gap-4">
        <span class="material-symbols-outlined text-accent text-2xl">location_on</span>
        <div>
          <p class="font-display font-bold text-text-primary">{contact.mapHeading}</p>
          <p class="text-text-secondary text-sm">{contact.mapText}</p>
        </div>
      </div>
    </div>
  </section>

  <script>
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const ok = document.getElementById('form-success');
    const err = document.getElementById('form-error');
    const btn = form?.querySelector('button[type=submit]') as HTMLButtonElement | null;

    // Mostrar error si el fallback sin JS redirigió con ?error=1
    if (new URLSearchParams(location.search).get('error') === '1') err?.classList.remove('hidden');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      err?.classList.add('hidden');
      if (btn) { btn.disabled = true; btn.classList.add('opacity-60'); }
      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Accept': 'application/json', 'X-Requested-With': 'fetch' },
          body: new FormData(form),
        });
        const data = await res.json().catch(() => ({ ok: false }));
        if (res.ok && data.ok) {
          form.classList.add('hidden');
          ok?.classList.remove('hidden');
          ok?.scrollIntoView({ behavior: 'smooth', block: 'center' });
        } else {
          throw new Error(data.error || 'fail');
        }
      } catch {
        err?.classList.remove('hidden');
      } finally {
        if (btn) { btn.disabled = false; btn.classList.remove('opacity-60'); }
      }
    });
  </script>

</Layout>
